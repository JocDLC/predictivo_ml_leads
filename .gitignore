# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
.venv/

# IDE
.vscode/
.idea/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Data files (processed files excluded, raw files tracked for reproducibility)
data/processed/*.csv

# Trained models
models/trained/*.pkl
models/trained/*.joblib

# MLflow
mlruns/
mlflow.db

# OS files
Thumbs.db
.DS_Store

# Temporary files
*.tmp
*.pdf
dataset_analysis.txt
prueba.py

# Excel files from Salesforce (too large for git)
*.xlsx
# Exception: test sample files for demo/validation
!data/test/*.xlsx

# Preprocessing artifacts (binary, regenerable with src/save_artifacts.py)
models/preprocessing_config.joblib
